local WindUI = loadstring(game:HttpGet("https://github.com/Footagesus/WindUI/releases/latest/download/main.lua"))()

-- [ Services ]
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local VirtualUser = game:GetService("VirtualUser")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")
local TeleportService = game:GetService("TeleportService")
local LocalPlayer = Players.LocalPlayer

-- [ Configuration ]
_G.AutoBoss = true
_G.AutoEgg100 = false
_G.AutoEgg250 = false

_G.AutoClick = false
_G.AutoBuySwords = false
_G.AutoBuyDNA = false
_G.AutoBuyClass = false

_G.AutoMerchant = false
_G.AutoWaterBoss = false

_G.AntiAFK = true
_G.AutoRejoin = true

_G.AutoDungeon = false
_G.SelectedMap = "Space"
_G.Difficulty = "Impossible"
_G.AutoAttack = false

------------------------------------------
-- [ 🎨 UI Window Setup ]
------------------------------------------
local Window = WindUI:CreateWindow({
    Title = "NiTroHub 🐰",
    Icon = "gamepad-2", 
    Author = "NiTroHub | Saber Simulator",
    Folder = "NiTroHubConfig",
    Transparent = true 
})

local EventTab = Window:Tab({ Title = "Events", Icon = "swords" })
local DungeonTab = Window:Tab({ Title = "Dungeon", Icon = "castle" })
local MainTab = Window:Tab({ Title = "Main", Icon = "monitor" }) 
local MerchantTab = Window:Tab({ Title = "Merchant", Icon = "shopping-cart" }) 
local ElementsTab = Window:Tab({ Title = "Elements", Icon = "box" }) 
local SettingsTab = Window:Tab({ Title = "Settings", Icon = "settings" })

-- [ Event Tab ]
EventTab:Section({ Title = "⚔️ Combat System" })
EventTab:Toggle({
    Title = "Auto Easter Boss",
    Desc = "ตีบอสกิจกรรมอัตโนมัติ",
    Icon = "skull", 
    Value = true,
    Callback = function(state)
        _G.AutoBoss = state
    end
})

EventTab:Section({ Title = "🥚 Egg Open" })
EventTab:Toggle({
    Title = "Auto Open Egg (100)",
    Value = false,
    Callback = function(state) _G.AutoEgg100 = state end
})
EventTab:Toggle({
    Title = "Auto Open Egg (250)",
    Value = false,
    Callback = function(state) _G.AutoEgg250 = state end
})

-- [ Dungeon Tab ]
DungeonTab:Section({ Title = "🚀 Dungeon" })
DungeonTab:Dropdown({
    Title = "Select Difficulty",
    Items = {"Easy", "Medium", "Hard", "Impossible"},
    Value = "Impossible",
    Callback = function(selected) _G.Difficulty = selected end
})
DungeonTab:Toggle({
    Title = "Auto Create & Join",
    Value = false,
    Callback = function(state) _G.AutoDungeon = state end
})
