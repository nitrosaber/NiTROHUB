local WindUI = loadstring(game:HttpGet("https://github.com/Footagesus/WindUI/releases/latest/download/main.lua"))()

-- [ Services ]
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local VirtualUser = game:GetService("VirtualUser")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")
local TeleportService = game:GetService("TeleportService")
local LocalPlayer = Players.LocalPlayer

-- [ Configuration ]
_G.AutoBoss = true
_G.AutoEgg100 = false
_G.AutoEgg250 = false

_G.AutoClick = false
_G.AutoBuySwords = false
_G.AutoBuyDNA = false
_G.AutoBuyClass = false

_G.AntiAFK = true
_G.AutoRejoin = true

_G.AutoDungeon = false
_G.SelectedMap = "Space"
_G.Difficulty = "Impossible"
_G.AutoAttack = false

------------------------------------------
-- [ 🎨 UI Window Setup ]
------------------------------------------
local Window = WindUI:CreateWindow({
    Title = "NiTroHub 🐰",
    Icon = "gamepad-2", 
    Author = "NiTroHub | Saber Simulator",
    Folder = "NiTroHubConfig",
    Transparent = true 
})

-- สร้าง Tabs (แก้ไขชื่อ Icon ให้ถูกต้อง ป้องกัน UI พัง)
local EventTab = Window:Tab({ Title = "Events", Icon = "swords" })
local DungeonTab = Window:Tab({ Title = "Dungeon", Icon = "castle" })
local MainTab = Window:Tab({ Title = "Main", Icon = "monitor" }) 
local MerchantTab = Window:Tab({ Title = "Merchant", Icon = "shopping-cart" }) -- แก้ไอคอน shop
local ElementsTab = Window:Tab({ Title = "Elements", Icon = "box" }) -- แก้จาก ElementsTap เป็น Tab และเปลี่ยนไอคอน
local SettingsTab = Window:Tab({ Title = "Settings", Icon = "settings" })

-- [ Event Tab ]
EventTab:Section({ Title = "⚔️ Combat System" })
EventTab:Toggle({
    Title = "Auto Easter Boss",
    Desc = "ตีบอสกิจกรรมอัตโนมัติ",
    Icon = "skull", 
    Value = true,
    Callback = function(state)
        _G.AutoBoss = state
        WindUI:Notify({Title = "System", Content = state and "🟢 เริ่มโจมตีบอส!" or "🔴 หยุดการโจมตี", Duration = 3})
    end
})

EventTab:Section({ Title = "🥚 Egg Open" })
EventTab:Toggle({
    Title = "Auto Open Egg (100)",
    Desc = "เปิดไข่ Event Egg 100",
    Value = false,
    Callback = function(state)
        _G.AutoEgg100 = state
    end
})

EventTab:Toggle({
    Title = "Auto Open Egg (250)",
    Desc = "เปิดไข่ Event Egg 250",
    Value = false,
    Callback = function(state)
        _G.AutoEgg250 = state
    end
})

