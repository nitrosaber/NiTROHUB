    Title = "Auto Rejoin",
    Desc = "เข้าเกมใหม่ทันทีถ้าเน็ตหลุดหรือเซิร์ฟเวอร์เตะ",
    Icon = "plug-zap", -- ไอคอนปลั๊กไฟ
    Value = true,
    Callback = function(state)
        _G.AutoRejoin = state
    end
})

SettingsTab:Section({ Title = "⚡ Performance" })

SettingsTab:Toggle({
    Title = "Black Screen Mode (Battery Saver)",
    Desc = "ปิดการแสดงผลหน้าจอเพื่อประหยัดแบตเตอรี่ (เครื่องเย็นขึ้นมาก)",
    Icon = "moon",
    Value = false,
    Callback = function(state)
        if state then
            -- ปิดการมองเห็นหน้าจอ (เปลี่ยนเป็นสีดำ)
            local Screen = Instance.new("Frame", game:GetService("CoreGui"))
            Screen.Name = "BlackScreenOverlay"
            Screen.Size = UDim2.new(1, 0, 1, 0)
            Screen.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            Screen.ZIndex = 999
            
            -- ปรับกราฟิกให้ต่ำสุด (ช่วยลด RAM)
            settings().Rendering.QualityLevel = 1
            game:GetService("RunService"):Set3dRenderingEnabled(false)
            
            WindUI:Notify({Title = "Power", Content = "เปิดโหมดประหยัดพลังงานแล้ว!", Duration = 3})
        else
            -- เปิดหน้าจอคืน
            if game:GetService("CoreGui"):FindFirstChild("BlackScreenOverlay") then
                game:GetService("CoreGui").BlackScreenOverlay:Destroy()
            end
            game:GetService("RunService"):Set3dRenderingEnabled(true)
            
            WindUI:Notify({Title = "Power", Content = "ปิดโหมดประหยัดพลังงานแล้ว", Duration = 3})
        end
    end
})


------------------------------------------
-- [ ⚙️ ระบบหลังบ้าน (ไม่แตะต้องระบบเดิม) ]
------------------------------------------

-- [1] ระบบอัปเดตบอสเวลาตาย (พื้นหลัง)
task.spawn(function()
    while true do
        task.wait(2)
        -- ถ้าบอสตายและหายไปจากแมพ
        if BossPath == nil or not BossPath.Parent then
            pcall(function()
                BossPath = workspace.Gameplay.RegionsLoaded.EasterEvent.Boss.BossHolder:WaitForChild("Boss", 5)
                bossArgs = {{ BossPath }}
            end)
        end
    end
end)

-- [2] ระบบตีบอส
local function GetEquippedSword()
    local char = LocalPlayer.Character
    if not char then return nil end
    for _, item in pairs(char:GetChildren()) do
        if SwordNames[item.Name] and item:FindFirstChild("RemoteClick") then
            return item
        end
    end
    return nil
end

task.spawn(function()
    while true do
        if _G.AutoBoss then
            local CurrentSword = GetEquippedSword()
            
            -- โค้ดตีบอสตัวเก่งของคุณ
            if CurrentSword and BossPath then
                CurrentSword.RemoteClick:FireServer(unpack(bossArgs))
                SwingRemote:FireServer()
            end
            task.wait(0.01)
        else
            task.wait(0.1)
        end
    end
end)

-- [3] ระบบเปิดไข่ Easter Event
task.spawn(function()
    while true do
        if _G.AutoEgg then
            pcall(function()
                local args = {
                    "BuyEgg",
                    "GA Egg"
                }
                UIActionRemote:FireServer(unpack(args))
            end)
            task.wait(1)
        else
            task.wait(0.1)
        end
    end
end)

-- [4] ระบบ Auto Click
task.spawn(function()
    while true do
        if _G.AutoClick then
            -- ส่งคำสั่งแกว่งดาบ
            SwingRemote:FireServer()
            task.wait(0.01) -- ความเร็วในการคลิก
        else
            task.wait(0.1)
        end
    end
end)

-- [100] ระบบ Anti-AFK
pcall(function()
    if getconnections then
        for _, connection in pairs(getconnections(LocalPlayer.Idled)) do
            if _G.AntiAFK then
                connection:Disable()
            end
        end
    end
end)

-- [101] ระบบ Auto Rejoin
local CoreGui = game:GetService("CoreGui")
local TeleportService = game:GetService("TeleportService")

task.spawn(function()
    pcall(function()
        -- ตรวจจับหน้าต่าง Error ของ Roblox
        local promptOverlay = CoreGui:WaitForChild("RobloxPromptGui"):WaitForChild("promptOverlay")
        
        promptOverlay.ChildAdded:Connect(function(child)
            if _G.AutoRejoin and child.Name == "ErrorPrompt" then
                print("NiTroHub: ตรวจพบการหลุด! กำลังเชื่อมต่อใหม่ใน 5 วินาที...")
                
                -- รอ 5 วินาทีให้เน็ตนิ่งก่อนเข้าใหม่ (กันเกมแครช)
                task.wait(5)
                
                -- โค้ดสำหรับเข้าเกมใหม่ (Teleport)
                if #Players:GetPlayers() <= 1 then
                    -- ถ้าในเซิร์ฟไม่มีคนเลย ให้เข้าเซิร์ฟใหม่ไปเลย
                    TeleportService:Teleport(game.PlaceId, LocalPlayer)
                else
                    -- พยายามกลับเข้าเซิร์ฟเวอร์เดิม (ถ้ายังว่าง)
                    TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, LocalPlayer)
                end
            end
        end)
    end)
end)

------------------------------------------
-- [ ⚙️ Core Logic - Dungeon System ]
------------------------------------------

-- 1. ระบบจัดการห้อง (Create & Start)
task.spawn(function()
    while true do
        if _G.AutoDungeon then
            pcall(function()
                local dungeonGroups = ReplicatedStorage:WaitForChild("DungeonGroups")
                local myGroupName = LocalPlayer.Name .. "'s Party"
                local myGroup = dungeonGroups:FindFirstChild(myGroupName)

                if not myGroup then
                    -- สร้างห้อง (อ้างอิงจาก v_u_1.CreateGroup)
                    UIAction:FireServer("CreateGroup", "Public", _G.SelectedMap, _G.Difficulty)
                else
                    -- ถ้าเป็นเจ้าของห้อง ให้กดเริ่ม (CheckIsOwner)
                    if myGroup:FindFirstChild("OwnerName") and myGroup.OwnerName.Value == LocalPlayer.Name then
                        UIAction:FireServer("StartDungeon")
                        -- สำรอง Remote Start เผื่อเวอร์ชั่นเปลี่ยน
                        local startRem = Events:FindFirstChild("StartDungeon") or Events:FindFirstChild("DungeonStart")
                        if startRem then startRem:FireServer() end
                    end
                end
            end)
        end
        task.wait(3) -- หน่วงเวลาเช็ค
    end
end)

--------------------------------------------------------
-- [ ⚔️ ระบบ Auto Warp To Enemy (เจาะจง Spawner) ]
--------------------------------------------------------
task.spawn(function()
    while true do
        if _G.AutoAttack then
            pcall(function()
                local DungeonStorage = workspace:FindFirstChild("DungeonStorage")
                if not DungeonStorage then return end

                -- 1. วนลูปหา Folder ที่เข้ารหัส (GUID)
                for _, dungeonFolder in pairs(DungeonStorage:GetChildren()) do
                    local important = dungeonFolder:FindFirstChild("Important")
                    if important then
                        -- 2. สแกนหาศัตรูที่เกิดจาก Spawner (เช่น BlueEnemySpawner, PurpleBossEnemySpawner)
                        -- โดยปกติศัตรูจะถูกสร้างไว้ในโฟลเดอร์ใกล้ๆ กัน หรือในโฟลเดอร์ชื่อ Enemies/Gameplay
                        local enemyFolder = dungeonFolder:FindFirstChild("Gameplay") or dungeonFolder:FindFirstChild("Enemies") or important
                        
                        for _, enemy in pairs(enemyFolder:GetDescendants()) do
                            -- ตรวจสอบว่าเป็นมอนสเตอร์ที่มีชีวิต (เลือด > 0)
                            if enemy:IsA("Model") and enemy:FindFirstChild("Humanoid") and enemy.Humanoid.Health > 0 then
                                
                                -- เช็คชื่อให้ตรงตามที่คุณส่งมา (Green, Blue, Red, Purple, Boss)
                                local name = enemy.Name:lower()
                                if name:find("bot") or name:find("boss") or name:find("enemy") then
                                    
                                    local head = enemy:FindFirstChild("Head")
                                    local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                                    
                                    if myRoot and head then
                                        -- 💡 วาร์ปไปสิงบนหัวแบบในรูป! (สูงขึ้นมา 3.5 หน่วยเพื่อความปลอดภัย)
                                        myRoot.CFrame = head.CFrame * CFrame.new(0, 3.5, 0)
                                        -- หันหน้าลงไปหาหัวบอส
                                        myRoot.CFrame = CFrame.new(myRoot.Position, head.Position)

                                        -- ⚔️ สั่งโจมตี
                                        local sword = GetEquippedSword()
                                        if sword then
                                            -- ยิง RemoteClick ไปที่หัวตรงๆ
                                            sword.RemoteClick:FireServer({{ head }})
                                            Events.SwingSaber:FireServer()
                                        end
                                        break -- ล็อคเป้าตัวนี้จนกว่าจะตาย
                                    end
                                end
                            end
                        end
                    end
                end
            end)
        end
        task.wait(0.01) -- ความเร็วระดับ Turbo สำหรับมือถือ
    end
end)


WindUI:Notify({Title = "NiTroHub Loaded", Content = "✨ โหลด UI เวอร์ชั่นพรีเมียมเสร็จสิ้น!", Duration = 5})
