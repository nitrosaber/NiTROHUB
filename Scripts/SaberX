local WindUI = loadstring(game:HttpGet("https://github.com/Footagesus/WindUI/releases/latest/download/main.lua"))()

-- [ Services ]
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local VirtualUser = game:GetService("VirtualUser")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")
local TeleportService = game:GetService("TeleportService")
local LocalPlayer = Players.LocalPlayer

-- [ Configuration ]
_G.AutoBoss = true
_G.AutoEgg100 = false
_G.AutoEgg250 = false

_G.AutoClick = false
_G.AutoClanQuest = false

_G.AutoBuySwords = false
_G.AutoBuyDNA = false
_G.AutoBuyClass = false

_G.AutoMerchant = false
_G.AutoWaterBoss = false
_G.WaterZone = "All" -- All, Basic, Advanced, Master, Grandmaster

_G.AntiAFK = true
_G.AutoRejoin = true

_G.AutoDungeon = false
_G.SelectedMap = "Space"
_G.Difficulty = "Impossible"
_G.AutoAttack = false

------------------------------------------
