local WindUI = loadstring(game:HttpGet("https://github.com/Footagesus/WindUI/releases/latest/download/main.lua"))()

-- [ Services ]
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local VirtualUser = game:GetService("VirtualUser")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")
local TeleportService = game:GetService("TeleportService")
local LocalPlayer = Players.LocalPlayer

-- [ Configuration ]
_G.AutoBoss = true
_G.AutoEgg100 = false
_G.AutoEgg250 = false

_G.AutoClick = false
_G.AutoBuySabers = false

_G.AntiAFK = true
_G.AutoRejoin = true

_G.AutoDungeon = false
_G.SelectedMap = "Space"
_G.Difficulty = "Impossible"
_G.AutoAttack = false

------------------------------------------
-- [ 🎨 UI Window Setup ] (ย้ายขึ้นมาบนสุดเพื่อให้เปิดทันที)
------------------------------------------
local Window = WindUI:CreateWindow({
    Title = "NiTroHub 🐰",
    Icon = "gamepad-2", 
    Author = "NiTroHub | Saber Simulator",
    Folder = "NiTroHubConfig",
    Transparent = true 
})

local EventTab = Window:Tab({ Title = "Events", Icon = "swords" })
local DungeonTab = Window:Tab({ Title = "Dungeon", Icon = "castle" })
local MainTab = Window:Tab({ Title = "Main", Icon = "geist:window" })
local SettingsTab = Window:Tab({ Title = "Settings", Icon = "settings" })

EventTab:Section({ Title = "⚔️ Combat System" })
EventTab:Toggle({
    Title = "Auto Easter Boss",
    Desc = "ตีบอสกิจกรรมอัตโนมัติ",
    Icon = "skull", 
    Value = true,
    Callback = function(state)
        _G.AutoBoss = state
        WindUI:Notify({Title = "System", Content = state and "🟢 เริ่มโจมตีบอส!" or "🔴 หยุดการโจมตี", Duration = 3})
    end
})

EventTab:Section({ Title = "🥚 Egg Open" })
EventTab:Toggle({
    Title = "Auto Open Egg (100)",
    Desc = "เปิดไข่ Event Egg 100",
    Icon = "egg", 
    Value = false,
    Callback = function(state)
        _G.AutoEgg100 = state
    end
})

EventTab:Toggle({
    Title = "Auto Open Egg (250)",
    Desc = "เปิดไข่ Event Egg 250",
    Icon = "egg", 
    Value = false,
    Callback = function(state)
        _G.AutoEgg250 = state
    end
})

DungeonTab:Section({ Title = "🚀 Dungeon" })
DungeonTab:Dropdown({
    Title = "Select Difficulty",
    Items = {"Easy", "Medium", "Hard", "Impossible"},
    Value = "Impossible",
    Callback = function(selected)
        _G.Difficulty = selected
    end
})
DungeonTab:Toggle({
    Title = "Auto Create & Join",
    Desc = "สร้างห้องและเริ่มดันเจี้ยนอัตโนมัติ",
    Value = false,
    Callback = function(state)
        _G.AutoDungeon = state
    end
})
DungeonTab:Toggle({
    Title = "Auto Attack",
    Desc = "ตีมอนสเตอร์/บอสอัตโนมัติเมื่อเข้าดันเจี้ยน",
    Value = false,
    Callback = function(state)
        _G.AutoAttack = state
    end
})

MainTab:Section({ Title = "🛎 Main" })
MainTab:Toggle({
    Title = "Auto Click",
    Desc = "แกว่งดาบฟาร์มพลังอัตโนมัติ",
    Icon = "mouse-pointer-click", 
    Value = false,
    Callback = function(state)
        _G.AutoClick = state
    end
})

MainTab:Section({ Title = "🛒 Auto Shop System" })
MainTab:Toggle({
    Title = "Auto Buy All Sabers",
    Desc = "ซื้อดาบทั้งหมดอัตโนมัติ",
    Icon = "shopping-bag",
    Value = false,
    Callback = function(state)
        _G.AutoBuySabers = state
    end
})

SettingsTab:Section({ Title = "🛡️ Protection System" })
SettingsTab:Toggle({
    Title = "Anti-AFK",
    Desc = "ป้องกันการโดนเตะเมื่อปล่อยบอททิ้งไว้นานๆ",
    Icon = "shield-check", 
    Value = true,
    Callback = function(state)
        _G.AntiAFK = state
    end
})
SettingsTab:Toggle({
    Title = "Auto Rejoin",
    Desc = "เข้าเกมใหม่ทันทีถ้าเน็ตหลุดหรือเซิร์ฟเวอร์เตะ",
    Icon = "plug-zap", 
    Value = true,
    Callback = function(state)
        _G.AutoRejoin = state
    end
})

SettingsTab:Section({ Title = "⚡ Performance" })
SettingsTab:Toggle({
    Title = "Black Screen Mode (Battery Saver)",
    Desc = "ปิดการแสดงผลหน้าจอเพื่อประหยัดแบตเตอรี่ (เครื่องเย็นขึ้นมาก)",
    Icon = "moon",
    Value = false,
    Callback = function(state)
        if state then
            local BlackFrame = Instance.new("Frame")
            BlackFrame.Name = "NiTroBlackScreen"
            BlackFrame.Parent = CoreGui
            BlackFrame.Size = UDim2.new(1, 0, 1, 0)
            BlackFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            BlackFrame.ZIndex = 9 
            RunService:Set3dRenderingEnabled(false)
            if setfpscap then setfpscap(120) end 
        else
            if CoreGui:FindFirstChild("NiTroBlackScreen") then
                CoreGui.NiTroBlackScreen:Destroy()
            end
            RunService:Set3dRenderingEnabled(true)
            if setfpscap then setfpscap(165) end
        end
    end
})

WindUI:Notify({Title = "NiTroHub Loaded", Content = "✨ โหลด UI เสร็จสิ้น!", Duration = 3})

------------------------------------------
-- [ ⚙️ โหลดข้อมูลเกม & ระบบหลังบ้าน (ไม่ทำให้ UI ค้าง) ]
------------------------------------------
task.spawn(function()
    local Events = ReplicatedStorage:WaitForChild("Events")
    local SwingRemote = Events:WaitForChild("SwingSaber")
    local UIActionRemote = Events:WaitForChild("UIAction") 
    local SwordModule = require(ReplicatedStorage.Modules.ItemInfo.Swords)

    local SwordNames = {}
    for name, _ in pairs(SwordModule) do
        SwordNames[name] = true
    end

    local BossPath = nil
    local bossArgs = {}

    -- [1] ระบบอัปเดตบอสเวลาตาย
    task.spawn(function()
        while true do
            task.wait(2)
            if BossPath == nil or not BossPath.Parent then
                pcall(function()
                    BossPath = workspace.Gameplay.RegionsLoaded.EasterEvent.Boss.BossHolder:WaitForChild("Boss", 5)
                    bossArgs = {{ BossPath }}
                end)
            end
        end
    end)

    -- ฟังก์ชันหาดาบ
    local function GetEquippedSword()
        local char = LocalPlayer.Character
        if not char then return nil end
        for _, item in pairs(char:GetChildren()) do
            if SwordNames[item.Name] and item:FindFirstChild("RemoteClick") then
                return item
            end
        end
        return nil
    end

    -- [2] ระบบตีบอส
    task.spawn(function()
        while true do
            if _G.AutoBoss and BossPath then
                local CurrentSword = GetEquippedSword()
                if CurrentSword then
                    CurrentSword.RemoteClick:FireServer(unpack(bossArgs))
                    SwingRemote:FireServer()
                end
                task.wait(0.01)
            else
                task.wait(0.1)
            end
        end
    end)

    -- [3] ระบบเปิดไข่
    task.spawn(function()
        while true do
            if _G.AutoEgg100 then
                pcall(function() UIActionRemote:FireServer("BuyEgg", "GA Egg") end)
                task.wait(1)
            else
                task.wait(0.1)
            end
        end
    end)

    task.spawn(function()
        while true do
            if _G.AutoEgg250 then
                pcall(function() UIActionRemote:FireServer("BuyEgg", "GB Egg") end)
                task.wait(1)
            else
                task.wait(0.1)
            end
        end
    end)

    -- [4] ระบบ Auto Click
    task.spawn(function()
        while true do
            if _G.AutoClick then
                SwingRemote:FireServer()
                task.wait(0.01)
            else
                task.wait(0.1)
            end
        end
    end)

     -- [5] ระบบ Auto Buy All Sabers
    task.spawn(function()
        while true do
            if _G.AutoBuySabers then
                pcall(function()
                    UIActionRemote:FireServer("BuyAllSabers")   -- ถ้า error ลอง "BuyAllSwords" หรือ "BuySabers"
                end)
                task.wait(1.5)
            else
                task.wait(0.5)
            end
        end
    end)

-- [6] ระบบ Dungeon (แก้ไขให้เสถียรขึ้น)
    task.spawn(function()
        while true do
            if _G.AutoDungeon then
                pcall(function()
                    local dungeonGroups = ReplicatedStorage:WaitForChild("DungeonGroups", 2)
                    local myGroupName = LocalPlayer.Name .. "'s Party"
                    local myGroup = dungeonGroups:FindFirstChild(myGroupName)

                    if not myGroup then
                        -- สร้างกลุ่มใหม่
                        UIActionRemote:FireServer("CreateGroup", "Public", _G.SelectedMap, _G.Difficulty)
                        task.wait(1.5) -- รอเกมสร้างกลุ่มเสร็จ
                    else
                        -- เป็นเจ้าของกลุ่ม → เริ่มดันเจี้ยน
                        if myGroup:FindFirstChild("OwnerName") and myGroup.OwnerName.Value == LocalPlayer.Name then
                            UIActionRemote:FireServer("StartDungeon")
                        end
                    end
                end)
            end
            task.wait(3)
        end
    end)

    -- [7] ระบบ Auto Attack (แก้ไขสำคัญตรงนี้!)
    task.spawn(function()
        while true do
            if _G.AutoAttack then
                pcall(function()
                    local DungeonStorage = workspace:FindFirstChild("DungeonStorage")
                    if not DungeonStorage then 
                        task.wait(0.5)
                        return 
                    end

                    for _, dungeonFolder in pairs(DungeonStorage:GetChildren()) do
                        local important = dungeonFolder:FindFirstChild("Important")
                        if not important then continue end

                        local enemyFolder = dungeonFolder:FindFirstChild("Gameplay") 
                                       or dungeonFolder:FindFirstChild("Enemies") 
                                       or important

                        for _, enemy in pairs(enemyFolder:GetDescendants()) do
                            if enemy:IsA("Model") 
                               and enemy:FindFirstChild("Humanoid") 
                               and enemy.Humanoid.Health > 0 then

                                local head = enemy:FindFirstChild("Head") or enemy:FindFirstChild("HumanoidRootPart")
                                local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")

                                if myRoot and head then
                                    -- Teleport + มองศัตรู
                                    myRoot.CFrame = head.CFrame * CFrame.new(0, 7, 0)
                                    myRoot.CFrame = CFrame.new(myRoot.Position, head.Position)

                                    -- ตี (แก้ไขตรง RemoteClick ให้ตรงกับระบบบอส)
                                    local sword = GetEquippedSword()
                                    if sword then
                                        sword.RemoteClick:FireServer({ enemy })   -- ← แก้ตรงนี้สำคัญ
                                        SwingRemote:FireServer()
                                    end

                                    break -- ตีตัวแรกที่เจอแล้วค่อยวนรอบใหม่
                                end
                            end
                        end
                    end
                end)
            end
            task.wait(0.01)
        end
    end)

-- [100] ระบบ Anti-AFK
task.spawn(function()
    while true do
        if _G.AntiAFK then
            pcall(function()
                VirtualUser:CaptureController()
                VirtualUser:ClickButton2(Vector2.new(0, 0))
            end)
        end
        task.wait(30) -- ทุก 30 วินาที (พอดีกับระบบ AFK ของ Roblox)
    end
end)

-- [101] ระบบ Auto Rejoin
task.spawn(function()
    pcall(function()
        local promptOverlay = CoreGui:WaitForChild("RobloxPromptGui"):WaitForChild("promptOverlay")
        promptOverlay.ChildAdded:Connect(function(child)
            if _G.AutoRejoin and child.Name == "ErrorPrompt" then
                task.wait(5)
                if #Players:GetPlayers() <= 1 then
                    TeleportService:Teleport(game.PlaceId, LocalPlayer)
                else
                    TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, LocalPlayer)
                end
            end
        end)
    end)
end)
