    Title = "Auto Rejoin",
    Value = true,
    Callback = function(state) _G.AutoRejoin = state end
})

SettingsTab:Section({ Title = "⚡ Performance" })
SettingsTab:Toggle({
    Title = "Black Screen Mode (Battery Saver)",
    Icon = "moon",
    Value = false,
    Callback = function(state)
        if state then
            local BlackFrame = Instance.new("Frame")
            BlackFrame.Name = "NiTroBlackScreen"
            BlackFrame.Parent = CoreGui
            BlackFrame.Size = UDim2.new(1, 0, 1, 0)
            BlackFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            BlackFrame.ZIndex = 9 
            RunService:Set3dRenderingEnabled(false)
            if setfpscap then setfpscap(120) end 
        else
            if CoreGui:FindFirstChild("NiTroBlackScreen") then
                CoreGui.NiTroBlackScreen:Destroy()
            end
            RunService:Set3dRenderingEnabled(true)
            if setfpscap then setfpscap(165) end
        end
    end
})

WindUI:Notify({Title = "NiTroHub Loaded", Content = "✨ โหลด UI เสร็จสิ้นพร้อมฉบับสมบูรณ์!", Duration = 3})

------------------------------------------
-- [ ⚙️ โหลดข้อมูลเกม & ระบบหลังบ้าน ]
------------------------------------------
task.spawn(function()
    local Events = ReplicatedStorage:WaitForChild("Events")
    local SwingRemote = Events:WaitForChild("SwingSaber")
    local UIActionRemote = Events:WaitForChild("UIAction") 
    local SwordModule = require(ReplicatedStorage.Modules.ItemInfo.Swords)

    local SwordNames = {}
    for name, _ in pairs(SwordModule) do SwordNames[name] = true end

    local BossPath = nil
    local bossArgs = {}

    -- [ ฟังก์ชันหาดาบ (เอามาไว้ข้างนอกให้ทุกคนใช้ได้) ]
    local function GetEquippedSword()
        local char = LocalPlayer.Character
        if not char then return nil end
        for _, item in pairs(char:GetChildren()) do
            if (SwordNames[item.Name] or item:FindFirstChild("RemoteClick")) then
                return item
            end
        end
        return nil
    end

    -- [1] ระบบอัปเดตบอส Easter (ทุกๆ 2 วินาที)
    task.spawn(function()
        while true do
            if BossPath == nil or not BossPath.Parent then
                pcall(function()
                    BossPath = workspace.Gameplay.RegionsLoaded.EasterEvent.Boss.BossHolder:WaitForChild("Boss", 5)
                    bossArgs = {{ BossPath }}
                end)
            end
            task.wait(2)
        end
    end)

    -- [2] ระบบตีบอส Easter
    task.spawn(function()
        while true do
            if _G.AutoBoss and BossPath then
                local CurrentSword = GetEquippedSword()
                if CurrentSword and CurrentSword:FindFirstChild("RemoteClick") then
                    CurrentSword.RemoteClick:FireServer(unpack(bossArgs))
                    SwingRemote:FireServer()
                end
                task.wait(0.01)
            else task.wait(0.1) end
        end
    end)

    -- [3] ระบบเปิดไข่
    task.spawn(function()
        while true do
            if _G.AutoEgg100 then pcall(function() UIActionRemote:FireServer("BuyEgg", "GA Egg") end) task.wait(1) end
            if _G.AutoEgg250 then pcall(function() UIActionRemote:FireServer("BuyEgg", "GB Egg") end) task.wait(1) end
            task.wait(0.1)
        end
    end)

    -- [4] ระบบ Auto Click & Clan Quest
    task.spawn(function()
        while true do
            if _G.AutoClick then
                SwingRemote:FireServer()
                task.wait(0.01)
            else task.wait(0.1) end
        end
    end)

    -- เช็ค Clan Quest แบบไม่แลค (รันทุกๆ 10 วิ ให้เซิร์ฟเวอร์เช็คให้เอง ไม่เปลืองแรม)
    task.spawn(function()
        while true do
            if _G.AutoClanQuest then
                pcall(function()
                    for i = 1, 3 do
                        UIActionRemote:FireServer("ClaimClanQuest", i)
                    end
                end)
            end
            task.wait(10)
        end
    end)

    -- [5] ระบบ Dungeon
    task.spawn(function()
        while true do
            if _G.AutoDungeon then
                pcall(function()
                    local dungeonGroups = ReplicatedStorage:WaitForChild("DungeonGroups", 2)
                    local myGroupName = LocalPlayer.Name .. "'s Party"
                    local myGroup = dungeonGroups:FindFirstChild(myGroupName)

                    if not myGroup then
                        UIActionRemote:FireServer("CreateGroup", "Public", _G.SelectedMap, _G.Difficulty)
                        task.wait(1.5)
                    else
                        if myGroup:FindFirstChild("OwnerName") and myGroup.OwnerName.Value == LocalPlayer.Name then
                            UIActionRemote:FireServer("StartDungeon")
                        end
                    end
                end)
            end
            task.wait(3)
        end
    end)

    -- [6] ระบบ Auto Warp To Enemy (Dungeon)
    task.spawn(function()
        while true do
            if _G.AutoAttack then
                pcall(function()
                    local DungeonStorage = workspace:FindFirstChild("DungeonStorage")
                    if not DungeonStorage then return end

                    for _, dungeonFolder in pairs(DungeonStorage:GetChildren()) do
                        local important = dungeonFolder:FindFirstChild("Important")
                        if important then
                            local enemyFolder = dungeonFolder:FindFirstChild("Gameplay") or dungeonFolder:FindFirstChild("Enemies") or important
                            for _, enemy in pairs(enemyFolder:GetDescendants()) do
                                if enemy:IsA("Model") and enemy:FindFirstChild("Humanoid") and enemy.Humanoid.Health > 0 then
                                    local name = enemy.Name:lower()
                                    if name:find("bot") or name:find("boss") or name:find("enemy") then
                                        local head = enemy:FindFirstChild("Head")
                                        local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                                        
                                        if myRoot and head then
                                            myRoot.CFrame = CFrame.new(myRoot.Position, head.Position)
                                            local sword = GetEquippedSword()
                                            if sword then
                                                sword.RemoteClick:FireServer({{ head }})
                                                SwingRemote:FireServer()
                                            end
                                            break
                                        end
                                    end
                                end
                            end
                        end
                    end
                end)
            end
            task.wait(0.01)
        end
    end)

    -- [7] ระบบ Auto Shop & Merchant 
    -- (แยก Merchant ออกมาเช็คทุก 10 วิ ไม่ให้รกเกม)
    task.spawn(function()
        while true do
            if _G.AutoBuySwords then pcall(function() Events:FindFirstChild("BuyAllSwords"):FireServer() end) end
            if _G.AutoBuyDNA then pcall(function() (Events:FindFirstChild("BuyAllBackpacks") or Events:FindFirstChild("BuyAllDNA")):FireServer() end) end
            if _G.AutoBuyClass then pcall(function() (Events:FindFirstChild("BuyAllClasses") or Events:FindFirstChild("BuyClass")):FireServer() end) end
            task.wait(0.5)
        end
    end)

    task.spawn(function()
        while true do
            if _G.AutoMerchant then
                pcall(function()
                    local merchantRemote = Events:FindFirstChild("BuyMerchantItem") or Events:FindFirstChild("MerchantBuy")
                    if merchantRemote then
                        for i = 1, 6 do merchantRemote:FireServer(i) end
                    end
                end)
            end
            task.wait(10) -- หน่วงเวลาไว้เยอะๆ ตอนซื้อของ Merchant จะได้ไม่แลคเครื่อง 
        end
    end)

    -- [8] ระบบ Elements ฉบับแก้แลค 100% (ชี้เป้าโดยตรง ไม่ Scan ทั่วแมพแล้ว)
    task.spawn(function()
        -- รวมที่อยู่ของโฟลเดอร์บอสน้ำแต่ละระดับ
        local waterLocations = {
            Basic = function() return workspace:FindFirstChild("Gameplay") and workspace.Gameplay:FindFirstChild("Map") and workspace.Gameplay.Map:FindFirstChild("ElementZones") and workspace.Gameplay.Map.ElementZones:FindFirstChild("Water") and workspace.Gameplay.Map.ElementZones.Water:FindFirstChild("Water") end,
            Advanced = function() return workspace:FindFirstChild("Gameplay") and workspace.Gameplay:FindFirstChild("RegionsLoaded") and workspace.Gameplay.RegionsLoaded:FindFirstChild("AdvancedWaterArea") and workspace.Gameplay.RegionsLoaded.AdvancedWaterArea:FindFirstChild("Important") and workspace.Gameplay.RegionsLoaded.AdvancedWaterArea.Important:FindFirstChild("Water") end,
            Master = function() return workspace:FindFirstChild("Gameplay") and workspace.Gameplay:FindFirstChild("RegionsLoaded") and workspace.Gameplay.RegionsLoaded:FindFirstChild("MasterWaterArea") and workspace.Gameplay.RegionsLoaded.MasterWaterArea:FindFirstChild("Important") and workspace.Gameplay.RegionsLoaded.MasterWaterArea.Important:FindFirstChild("Water") end,
            Grandmaster = function() return workspace:FindFirstChild("Gameplay") and workspace.Gameplay:FindFirstChild("RegionsLoaded") and workspace.Gameplay.RegionsLoaded:FindFirstChild("GrandmasterWaterArea") and workspace.Gameplay.RegionsLoaded.GrandmasterWaterArea:FindFirstChild("Important") and workspace.Gameplay.RegionsLoaded.GrandmasterWaterArea.Important:FindFirstChild("Water") end
        }

        local function getTargetFolders()
            local folders = {}
            if _G.WaterZone == "All" then
                for k, v in pairs(waterLocations) do
                    local f = v()
                    if f then table.insert(folders, f) end
                end
            else
                if waterLocations[_G.WaterZone] then
                    local f = waterLocations[_G.WaterZone]()
                    if f then table.insert(folders, f) end
                end
            end
            return folders
        end

        while true do
            if _G.AutoWaterBoss then
                pcall(function()
                    local targetFolders = getTargetFolders()
                    local targetFound = false

                    -- ค้นหาเฉพาะในโฟลเดอร์บอสเท่านั้น ไม่วนสแกนของที่ไม่เกี่ยวข้อง (ใช้ GetChildren ไม่ใช่ GetDescendants)
                    for _, folder in ipairs(targetFolders) do
                        for _, obj in ipairs(folder:GetChildren()) do 
                            if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj.Humanoid.Health > 0 then
                                local name = obj.Name:lower()
                                if name:find("water") and (name:find("boss") or name:find("golem")) then
                                    local CurrentSword = GetEquippedSword()
                                    if CurrentSword and CurrentSword:FindFirstChild("RemoteClick") then
                                        CurrentSword.RemoteClick:FireServer({ obj })
                                        SwingRemote:FireServer()
                                        targetFound = true
                                    end
                                end
                            end
                        end
                    end
                    
                    if not targetFound then task.wait(0.5) end -- ถ้าตายหมดให้รอสปาวน์ใหม่
                end)
                task.wait(0.01) -- ฟันรัวๆ เฉพาะตอนตีบอส
            else
                task.wait(0.5)
            end
        end
    end)
end) -- สิ้นสุด Block โหลดระบบหลัก

-- [100] ระบบ Anti-AFK
task.spawn(function()
    while true do
        if _G.AntiAFK then
            pcall(function()
                VirtualUser:CaptureController()
                VirtualUser:ClickButton2(Vector2.new(0, 0))
            end)
        end
        task.wait(30)
    end
end)

-- [101] ระบบ Auto Rejoin
task.spawn(function()
    pcall(function()
        local promptOverlay = CoreGui:WaitForChild("RobloxPromptGui"):WaitForChild("promptOverlay")
        promptOverlay.ChildAdded:Connect(function(child)
            if _G.AutoRejoin and child.Name == "ErrorPrompt" then
                task.wait(5)
                if #Players:GetPlayers() <= 1 then
                    TeleportService:Teleport(game.PlaceId, LocalPlayer)
                else
                    TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, LocalPlayer)
                end
            end
        end)
    end)
end)
