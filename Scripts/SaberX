    Value = false,
    Callback = function(state) _G.AutoMerchant = state end
})

-- [ Elements Tab ]
ElementsTab:Section({ Title = "🌊 Water Element Boss" })
ElementsTab:Toggle({
    Title = "Auto Water Boss / Golem",
    Desc = "ตีบอสธาตุน้ำทุกโซนแบบ Remote (ไม่ต้องเดินไปหา)",
    Icon = "droplets", 
    Value = false,
    Callback = function(state)
        _G.AutoWaterBoss = state
        WindUI:Notify({Title = "Elements", Content = state and "🟢 เริ่มฟาร์มบอสน้ำ!" or "🔴 หยุด", Duration = 3})
    end
})

-- [ Settings Tab ]
SettingsTab:Section({ Title = "🛡️ Protection System" })
SettingsTab:Toggle({
    Title = "Anti-AFK",
    Value = true,
    Callback = function(state) _G.AntiAFK = state end
})
SettingsTab:Toggle({
    Title = "Auto Rejoin",
    Value = true,
    Callback = function(state) _G.AutoRejoin = state end
})

SettingsTab:Section({ Title = "⚡ Performance" })
SettingsTab:Toggle({
    Title = "Black Screen Mode (Battery Saver)",
    Icon = "moon",
    Value = false,
    Callback = function(state)
        if state then
            local BlackFrame = Instance.new("Frame")
            BlackFrame.Name = "NiTroBlackScreen"
            BlackFrame.Parent = CoreGui
            BlackFrame.Size = UDim2.new(1, 0, 1, 0)
            BlackFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            BlackFrame.ZIndex = 9 
            RunService:Set3dRenderingEnabled(false)
            if setfpscap then setfpscap(120) end 
        else
            if CoreGui:FindFirstChild("NiTroBlackScreen") then
                CoreGui.NiTroBlackScreen:Destroy()
            end
            RunService:Set3dRenderingEnabled(true)
            if setfpscap then setfpscap(165) end
        end
    end
})

WindUI:Notify({Title = "NiTroHub Loaded", Content = "✨ โหลด UI เสร็จสิ้น!", Duration = 3})

------------------------------------------
-- [ ⚙️ โหลดข้อมูลเกม & ระบบหลังบ้าน ]
------------------------------------------
task.spawn(function()
    local Events = ReplicatedStorage:WaitForChild("Events")
    local SwingRemote = Events:WaitForChild("SwingSaber")
    local UIActionRemote = Events:WaitForChild("UIAction") 
    local SwordModule = require(ReplicatedStorage.Modules.ItemInfo.Swords)

    local SwordNames = {}
    for name, _ in pairs(SwordModule) do
        SwordNames[name] = true
    end

    local BossPath = nil
    local bossArgs = {}

    -- [ ฟังก์ชันหาดาบที่ใช้งานอยู่ ]
    local function GetEquippedSword()
        local char = LocalPlayer.Character
        if not char then return nil end
        for _, item in pairs(char:GetChildren()) do
            if (SwordNames[item.Name] or item:FindFirstChild("RemoteClick")) then
                return item
            end
        end
        return nil
    end

    -- [1] ระบบอัปเดตบอส Easter (กิจกรรม)
    task.spawn(function()
        while true do
            task.wait(2)
            if BossPath == nil or not BossPath.Parent then
                pcall(function()
                    BossPath = workspace.Gameplay.RegionsLoaded.EasterEvent.Boss.BossHolder:WaitForChild("Boss", 5)
                    bossArgs = {{ BossPath }}
                end)
            end
        end
    end)

    -- [2] ระบบตีบอส Easter
    task.spawn(function()
        while true do
            if _G.AutoBoss and BossPath then
                local CurrentSword = GetEquippedSword()
                if CurrentSword and CurrentSword:FindFirstChild("RemoteClick") then
                    CurrentSword.RemoteClick:FireServer(unpack(bossArgs))
                    SwingRemote:FireServer()
                end
                task.wait(0.01)
            else
                task.wait(0.1)
            end
        end
    end)

    -- [3] ระบบเปิดไข่
    task.spawn(function()
        while true do
            if _G.AutoEgg100 then
                pcall(function() UIActionRemote:FireServer("BuyEgg", "GA Egg") end)
                task.wait(1)
            end
            if _G.AutoEgg250 then
                pcall(function() UIActionRemote:FireServer("BuyEgg", "GB Egg") end)
                task.wait(1)
            end
            task.wait(0.1)
        end
    end)

    -- [4] ระบบ Auto Click
    task.spawn(function()
        while true do
            if _G.AutoClick then
                SwingRemote:FireServer()
                task.wait(0.01)
            else
                task.wait(0.1)
            end
        end
    end)

    -- [5] ระบบ Dungeon
    task.spawn(function()
        while true do
            if _G.AutoDungeon then
                pcall(function()
                    local dungeonGroups = ReplicatedStorage:WaitForChild("DungeonGroups", 2)
                    local myGroupName = LocalPlayer.Name .. "'s Party"
                    local myGroup = dungeonGroups:FindFirstChild(myGroupName)

                    if not myGroup then
                        UIActionRemote:FireServer("CreateGroup", "Public", _G.SelectedMap, _G.Difficulty)
                        task.wait(1.5)
                    else
                        if myGroup:FindFirstChild("OwnerName") and myGroup.OwnerName.Value == LocalPlayer.Name then
                            UIActionRemote:FireServer("StartDungeon")
                        end
                    end
                end)
            end
            task.wait(3)
        end
    end)

    -- [6] ระบบ Auto Warp To Enemy (Dungeon)
    task.spawn(function()
        while true do
            if _G.AutoAttack then
                pcall(function()
                    local DungeonStorage = workspace:FindFirstChild("DungeonStorage")
                    if not DungeonStorage then return end

                    for _, dungeonFolder in pairs(DungeonStorage:GetChildren()) do
                        local important = dungeonFolder:FindFirstChild("Important")
                        if important then
                            local enemyFolder = dungeonFolder:FindFirstChild("Gameplay") or dungeonFolder:FindFirstChild("Enemies") or important
                            for _, enemy in pairs(enemyFolder:GetDescendants()) do
                                if enemy:IsA("Model") and enemy:FindFirstChild("Humanoid") and enemy.Humanoid.Health > 0 then
                                    local name = enemy.Name:lower()
                                    if name:find("bot") or name:find("boss") or name:find("enemy") then
                                        local head = enemy:FindFirstChild("Head")
                                        local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                                        
                                        if myRoot and head then
                                            myRoot.CFrame = head.CFrame * CFrame.new(0, 7, 0)
                                            myRoot.CFrame = CFrame.new(myRoot.Position, head.Position)

                                            local sword = GetEquippedSword()
                                            if sword then
                                                sword.RemoteClick:FireServer({{ head }})
                                                SwingRemote:FireServer()
                                            end
                                            break
                                        end
                                    end
                                end
                            end
                        end
                    end
                end)
            end
            task.wait(0.01)
        end
    end)

    -- [7] ระบบ Auto Shop & Merchant
    task.spawn(function()
        while true do
            pcall(function()
                if _G.AutoBuySwords then
                    local buySwords = Events:FindFirstChild("BuyAllSwords")
                    if buySwords then buySwords:FireServer() end
                end
                
                if _G.AutoBuyDNA then
                    local buyDNA = Events:FindFirstChild("BuyAllBackpacks") or Events:FindFirstChild("BuyAllDNA")
                    if buyDNA then buyDNA:FireServer() end
                end
                
                if _G.AutoBuyClass then
                    local buyClass = Events:FindFirstChild("BuyAllClasses") or Events:FindFirstChild("BuyClass")
                    if buyClass then buyClass:FireServer() end
                end

                if _G.AutoMerchant then
                    local merchantRemote = Events:FindFirstChild("BuyMerchantItem") or Events:FindFirstChild("MerchantBuy")
                    if merchantRemote then
                        for i = 1, 6 do merchantRemote:FireServer(i) end
                    end
                end
            end)
            task.wait(0.5)
        end
    end)

    -- [8] ระบบ Elements (ตีมอนสเตอร์ธาตุน้ำแบบ Remote 100%)
    task.spawn(function()
        local currentWaterTarget = nil

        while true do
            if _G.AutoWaterBoss then
                pcall(function()
                    -- เช็คว่าเป้าหมายเดิมตายหรือยัง ถ้าตายให้หาตัวใหม่
                    if not currentWaterTarget or not currentWaterTarget.Parent or not currentWaterTarget:FindFirstChild("Humanoid") or currentWaterTarget.Humanoid.Health <= 0 then
                        currentWaterTarget = nil
                        
                        -- ฟังก์ชันสแกนหามอนสเตอร์ทั้งหมดในแมพที่มีคำว่า "water"
                        local function findWaterEnemy(folder)
                            if not folder then return nil end
                            for _, obj in pairs(folder:GetDescendants()) do
                                if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj.Humanoid.Health > 0 then
                                    local name = obj.Name:lower()
                                    if name:find("water") and (name:find("boss") or name:find("golem")) then
                                        return obj
                                    end
                                end
                            end
                            return nil
                        end

                        currentWaterTarget = findWaterEnemy(workspace:FindFirstChild("Gameplay"))
                    end

                    -- ถ่าเจอมอนสเตอร์น้ำ ให้ยืนฟันจากที่ที่เราอยู่ได้เลย
                    if currentWaterTarget then
                        local CurrentSword = GetEquippedSword()
                        if CurrentSword and CurrentSword:FindFirstChild("RemoteClick") then
                            CurrentSword.RemoteClick:FireServer({ currentWaterTarget })
                            SwingRemote:FireServer()
                        end
                    end
                end)
                task.wait(0.01) -- ฟันรัวๆ
            else
                currentWaterTarget = nil
                task.wait(0.5)
            end
        end
    end)

end) -- สิ้นสุด Block โหลดระบบหลัก

-- [100] ระบบ Anti-AFK
task.spawn(function()
    while true do
        if _G.AntiAFK then
            pcall(function()
                VirtualUser:CaptureController()
                VirtualUser:ClickButton2(Vector2.new(0, 0))
            end)
        end
        task.wait(30)
    end
end)

-- [101] ระบบ Auto Rejoin
task.spawn(function()
    pcall(function()
        local promptOverlay = CoreGui:WaitForChild("RobloxPromptGui"):WaitForChild("promptOverlay")
        promptOverlay.ChildAdded:Connect(function(child)
            if _G.AutoRejoin and child.Name == "ErrorPrompt" then
                task.wait(5)
                if #Players:GetPlayers() <= 1 then
                    TeleportService:Teleport(game.PlaceId, LocalPlayer)
                else
                    TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, LocalPlayer)
                end
            end
        end)
    end)
end)

