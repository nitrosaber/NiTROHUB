local WindUI = loadstring(game:HttpGet("https://github.com/Footagesus/WindUI/releases/latest/download/main.lua"))()

-- [ Services ]
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local VirtualUser = game:GetService("VirtualUser")
local LocalPlayer = Players.LocalPlayer

-- [ Variables ]
local SwingRemote = ReplicatedStorage:WaitForChild("Events"):WaitForChild("SwingSaber")
local UIActionRemote = ReplicatedStorage:WaitForChild("Events"):WaitForChild("UIAction") -- ✨ เพิ่มสำหรับเปิดไข่
local SwordModule = require(ReplicatedStorage.Modules.ItemInfo.Swords)

local SwordNames = {}
for name, _ in pairs(SwordModule) do
    SwordNames[name] = true
end

-- อ้างอิง Path ของบอส (แกนหลักที่ทำงานได้ 100%)
local BossPath = workspace:WaitForChild("Gameplay", 10)
    :WaitForChild("RegionsLoaded", 10)
    :WaitForChild("EasterEvent", 10)
    :WaitForChild("Boss", 10)
    :WaitForChild("BossHolder", 10)
    :WaitForChild("Boss", 10)

local bossArgs = {{ BossPath }}
_G.AutoBoss = true
_G.AutoEgg = false

_G.AutoClick = false

_G.AntiAFK = true

------------------------------------------
-- [ 🎨 UI Window Setup ]
------------------------------------------
-- ตั้งค่าหน้าต่างหลัก
local Window = WindUI:CreateWindow({
    Title = "NiTroHub 🐰",
    Icon = "gamepad-2", -- ไอคอนจอยเกม
    Author = "NiTroHub | Saber Simulator",
    Folder = "NiTroHubConfig",
    Transparent = true -- ทำให้หน้าต่างมีความโปร่งแสงสวยงาม
})

-- สร้าง Tabs
local EventTab = Window:Tab({ Title = "Events", Icon = "swords" })
local MainTab = Window:Tab({ Title = "Main", Icon = "geist:window" })
local SettingsTab = Window:Tab({ Title = "Settings", Icon = "settings" })

-- [ หมวดหมู่ Combat ในหน้า Event ]
EventTab:Section({ Title = "⚔️ Combat System" })

EventTab:Toggle({
    Title = "Auto Easter Boss",
    Desc = "ตีบอสกิจกรรมอัตโนมัติ",
    Icon = "skull", -- ไอคอนหัวกะโหลก
    Value = true,
    Callback = function(state)
        _G.AutoBoss = state
        if state then
            WindUI:Notify({Title = "System", Content = "🟢 เริ่มโจมตีบอส!", Duration = 3})
        else
            WindUI:Notify({Title = "System", Content = "🔴 หยุดการโจมตี", Duration = 3})
        end
    end
})

EventTab:Toggle({
    Title = "Auto Open Egg",
    Desc = "เปิดไข่ Event Egg 100",
    Icon = "egg", -- ไอคอนไข่
    Value = false,
    Callback = function(state)
        _G.AutoEgg = state
        if state then
            WindUI:Notify({Title = "System", Content = "🥚 เริ่มเปิดไข่!", Duration = 3})
        else
            WindUI:Notify({Title = "System", Content = "🔴 หยุดการเปิดไข่", Duration = 3})
        end
    end
})

-- [ หมวดหมู่ Main ในหน้า Main ]
MainTab:Section({ Title = "🛎 Main" })

MainTab:Toggle({
    Title = "Auto Click",
    Desc = "แกว่งดาบฟาร์มพลังอัตโนมัติ",
    Icon = "mouse-pointer-click", 
    Value = false,
    Callback = function(state)
        _G.AutoClick = state
    end
})


-- [ หมวดหมู่ Protection ในหน้า Settings ]
SettingsTab:Section({ Title = "🛡️ Protection System" })

SettingsTab:Toggle({
    Title = "Anti-AFK",
    Desc = "ป้องกันการโดนเตะเมื่อปล่อยบอททิ้งไว้นานๆ",
    Icon = "shield-check", -- ไอคอนโล่ป้องกัน
    Value = true,
    Callback = function(state)
        _G.AntiAFK = state
    end
})

------------------------------------------
-- [ ⚙️ ระบบหลังบ้าน (ไม่แตะต้องระบบเดิม) ]
------------------------------------------

-- [1] ระบบอัปเดตบอสเวลาตาย (พื้นหลัง)
task.spawn(function()
    while true do
        task.wait(2)
        -- ถ้าบอสตายและหายไปจากแมพ
        if BossPath == nil or not BossPath.Parent then
            pcall(function()
                BossPath = workspace.Gameplay.RegionsLoaded.EasterEvent.Boss.BossHolder:WaitForChild("Boss", 5)
                bossArgs = {{ BossPath }}
            end)
        end
    end
end)

-- [2] ระบบ Anti-AFK
pcall(function()
    if getconnections then
        for _, connection in pairs(getconnections(LocalPlayer.Idled)) do
            if _G.AntiAFK then
                connection:Disable()
            end
        end
    end
end)

-- [3] ระบบตีบอส
local function GetEquippedSword()
    local char = LocalPlayer.Character
    if not char then return nil end
    for _, item in pairs(char:GetChildren()) do
        if SwordNames[item.Name] and item:FindFirstChild("RemoteClick") then
            return item
        end
    end
    return nil
end

task.spawn(function()
    while true do
        if _G.AutoBoss then
            local CurrentSword = GetEquippedSword()
            
            -- โค้ดตีบอสตัวเก่งของคุณ
            if CurrentSword and BossPath then
                CurrentSword.RemoteClick:FireServer(unpack(bossArgs))
                SwingRemote:FireServer()
            end
            task.wait(0.01)
        else
            task.wait(0.1)
        end
    end
end)

-- [4] ระบบเปิดไข่ Easter Event
task.spawn(function()
    while true do
        if _G.AutoEgg then
            pcall(function()
                local args = {
                    "BuyEgg",
                    "GA Egg"
                }
                UIActionRemote:FireServer(unpack(args))
            end)
            task.wait(1)
        else
            task.wait(0.1)
        end
    end
end)

-- [5] ระบบ Auto Click
task.spawn(function()
    while true do
        if _G.AutoClick then
            -- ส่งคำสั่งแกว่งดาบ
            SwingRemote:FireServer()
            task.wait(0.01) -- ความเร็วในการคลิก
        else
            task.wait(0.1)
        end
    end
end)


WindUI:Notify({Title = "NiTroHub Loaded", Content = "✨ โหลด UI เวอร์ชั่นพรีเมียมเสร็จสิ้น!", Duration = 5})
